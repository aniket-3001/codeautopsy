    {
      "id": "resolution-rate",
      "panelTypes": "value",
      "title": "Resolution Rate %",
      "description": "Share of crashes Fix Bot has resolved",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "Resolved",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy' AND codeautopsy.resolved = true" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            },
            {
              "dataSource": "traces",
              "queryName": "B",
              "expression": "B",
              "disabled": false,
              "legend": "Total",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": [
            { "disabled": false, "expression": "(A/B)*100", "legend": "Resolution Rate %", "queryName": "F1" }
          ]
        }
      }
    },

    { "id": "row-time", "panelTypes": "row", "query": {}, "title": "Blast Radius Over Time" },

    {
      "id": "blast-radius-over-time",
      "panelTypes": "graph",
      "title": "Blast Radius Over Time",
      "description": "Sum of blast radius per crash, over time",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
