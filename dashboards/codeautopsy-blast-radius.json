              "legend": "Unresolved",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy' AND codeautopsy.resolved = false" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
      }
    },

