  "variables": {},
  "widgets": [
    { "id": "row-overview", "panelTypes": "row", "query": {}, "title": "Blast Radius Overview" },

    {
      "id": "total-crashes",
      "panelTypes": "value",
      "title": "Total Crashes Autopsied",
      "description": "Every crash CodeAutopsy has traced back to an AI decision",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "Crashes",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
      }
    },

    {
      "id": "unresolved-crashes",
      "panelTypes": "value",
      "title": "Unresolved Crashes",
