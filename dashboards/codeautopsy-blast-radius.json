        { "dataType": "string", "id": "codeautopsy.cause_of_death--string--tag--false", "isColumn": false, "isJSON": false, "key": "codeautopsy.cause_of_death", "type": "tag" },
        { "dataType": "string", "id": "deployment.commit.sha--string--tag--false", "isColumn": false, "isJSON": false, "key": "deployment.commit.sha", "type": "tag" }
      ],
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
