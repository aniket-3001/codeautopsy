      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "Blast Radius",
              "stepInterval": 60,
              "aggregations": [ { "expression": "sum(codeautopsy.blast_radius)" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
      }
