    {
      "id": "crashes-by-risk-flag",
      "panelTypes": "table",
      "title": "Crashes by Risk Flag",
      "description": "Which write-time risk flags correlate most with production crashes",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy' AND codeautopsy.risk_flags EXISTS AND codeautopsy.risk_flags != ''" },
              "groupBy": [
                { "dataType": "string", "id": "codeautopsy.risk_flags--string--tag--false", "isColumn": false, "isJSON": false, "key": "codeautopsy.risk_flags", "type": "tag" }
              ],
              "having": { "expression": "" },
              "limit": 10,
              "orderBy": [ { "columnName": "count()", "order": "desc" } ],
              "functions": []
            }
          ],
          "queryFormulas": []
