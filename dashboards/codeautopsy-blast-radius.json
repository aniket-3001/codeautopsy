              "stepInterval": 60,
              "aggregations": [ { "expression": "sum(codeautopsy.blast_radius)" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
      }
    },

    {
      "id": "resolved-vs-unresolved-time",
      "panelTypes": "graph",
      "title": "Resolved vs Unresolved Crashes",
