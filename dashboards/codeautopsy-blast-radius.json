      "panelTypes": "table",
      "title": "Crashes by File",
      "description": "Which files are crashing the most, worst first",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [
                { "dataType": "string", "id": "code.filepath--string--tag--false", "isColumn": false, "isJSON": false, "key": "code.filepath", "type": "tag" }
              ],
              "having": { "expression": "" },
              "limit": 10,
              "orderBy": [ { "columnName": "count()", "order": "desc" } ],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
      }
