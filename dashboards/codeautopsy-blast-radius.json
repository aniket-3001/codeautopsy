      "panelTypes": "list",
      "title": "Unresolved Crash Queue",
      "description": "Newest unresolved crashes, ready for Fix Bot",
      "timePreferance": "GLOBAL_TIME",
      "selectedTracesFields": [
        { "dataType": "string", "id": "timestamp--string--tag--true", "isColumn": true, "isJSON": false, "key": "timestamp", "type": "tag" },
