      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "dataSource": "traces",
              "queryName": "A",
              "expression": "A",
              "disabled": false,
              "legend": "{{codeautopsy.resolved}}",
              "stepInterval": 60,
              "aggregations": [ { "expression": "count()" } ],
              "filter": { "expression": "name = 'codeautopsy.autopsy'" },
              "groupBy": [
                { "dataType": "bool", "id": "codeautopsy.resolved--bool--tag--false", "isColumn": false, "isJSON": false, "key": "codeautopsy.resolved", "type": "tag" }
              ],
              "having": { "expression": "" },
              "limit": null,
              "orderBy": [],
              "functions": []
            }
          ],
          "queryFormulas": []
        }
