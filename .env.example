# Copy to .env and fill in.  .env is git-ignored — your key never enters git or chat.
#
# SigNoz Cloud ingestion (Settings → Ingestion Settings in the SigNoz Cloud UI):
#   - Region endpoints:
#       US:  https://ingest.us.signoz.cloud:443
#       EU:  https://ingest.eu.signoz.cloud:443
#       IN:  https://ingest.in.signoz.cloud:443
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.us.signoz.cloud:443
SIGNOZ_INGESTION_KEY=paste-your-ingestion-key-here

# For local self-host instead, use:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#   (and leave SIGNOZ_INGESTION_KEY blank)
